# ==========================================================================
# n8n Automation Dashboard — Environment Variables (PLACEHOLDERS ONLY)
# Copy to .env.local for local dev. NEVER commit real secrets.
# All server-side secrets must live in Render/Supabase/CI secret managers.
# ==========================================================================

# --- App ---
APP_ENV=development
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_GITHUB_OAUTH=false

# --- Supabase (public, safe to expose) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only fallbacks (server-auth reads these if NEXT_PUBLIC_* absent)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Server-only: required for the n8n sync job to write cached metrics. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Dashboard fixed login (verified by Supabase Auth) ---
DASHBOARD_AUTH_USERNAME=
DASHBOARD_AUTH_EMAIL=
DASHBOARD_URL=https://n8n-dashboard.maximo-seo.ai
NEXT_PUBLIC_DASHBOARD_URL=https://n8n-dashboard.maximo-seo.ai

# --- Login rate limiting (Upstash Redis) ---
AUTH_RATE_LIMIT_REDIS_URL=
AUTH_RATE_LIMIT_REDIS_TOKEN=
RESET_RATE_LIMIT_REDIS_URL=
RESET_RATE_LIMIT_REDIS_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- n8n (read-only REST API for sync + live views) ---
# Get from n8n -> Settings -> API. Server-side only. Never commit real values.
# Legacy single-instance compatibility for existing routes:
N8N_API_KEY=
N8N_BASE_URL=https://websiseo.app.n8n.cloud
# Multi-instance monitoring registry:
N8N_INSTANCE_1_URL=https://maximoseo.app.n8n.cloud
N8N_INSTANCE_1_API_KEY=
N8N_INSTANCE_2_URL=https://websiseo.app.n8n.cloud
N8N_INSTANCE_2_API_KEY=
# Optional named aliases accepted by the server-side registry.
# These are alternate identifiers for the same two managed instances, not extra instances.
# Precedence: numbered vars above win first; named aliases are fallbacks for readability/ops scripts.
# Prefer numbered vars in Render blueprints and named aliases in local/operator notes when clearer.
N8N_MAXIMOSEO_BASE_URL=
N8N_MAXIMOSEO_API_KEY=
N8N_WEBSISEO_BASE_URL=
N8N_WEBSISEO_API_KEY=
N8N_NOFOLLOW_SETUP_WEBHOOK_URL=

# --- n8n sync job (machine-triggered cron/CI) ---
# Shared secret the cron/CI script sends as `x-sync-secret` to /api/n8n/sync.
SYNC_SECRET=
# Optional: n8n webhook that orchestrates a "Run Full Site Analysis" SEO pack.
N8N_SITE_PACK_WEBHOOK_URL=

# --- AI providers (optional features) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Crawl / browser automation ---
BROWSERLESS_API_KEY=
FIRECRAWL_API_KEY=

# --- SEO data ---
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Notifications / tasks ---
RESEND_API_KEY=
TELEGRAM_BOT_TOKEN=
# Chat id alerts are sent to (used with TELEGRAM_BOT_TOKEN by /api/n8n/alerts).
TELEGRAM_ALERT_CHAT_ID=
ALERT_EMAIL=
AGENT_TASKS_WEBHOOK_URL=
AGENT_TASKS_WEBHOOK_SECRET=

# --- Cron auth ---
CRON_SECRET=

# --- Google service account (nofollow clone sheets) ---
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
